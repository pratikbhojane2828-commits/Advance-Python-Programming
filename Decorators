#login decorator
def logger(func):
    def wrapper():
        print("function started")
        func()
        print("function ended")
    return wrapper

@logger
def display():
    print("welcome Student")

display()

#authentication decorator
logged_in=True
def login_required(func):
    def wrapper():
        if logged_in:
            func()
        else:
            print("please login first")
    return wrapper

@login_required
def profile():
    print("welcome to youe profile")

profile()

#execution time decorator
import time
def timer(func):
    def wrapper():
        start=time.time()
        func()
        end=time.time()
        print("Execution time=",end,start)
    return wrapper

@timer
def numbers():
    for i in range(1000000):
        pass

numbers()
